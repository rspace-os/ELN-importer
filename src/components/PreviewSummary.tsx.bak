import React from 'react';
import { 
  FileText, 
  Package, 
  AlertTriangle, 
  CheckCircle, 
  Clock,
  Users,
  Calendar,
  Hash
} from 'lucide-react';
import { PreviewSession } from '../types/eln';
import clsx from 'clsx';

interface PreviewSummaryProps {
  session: PreviewSession;
}

export function PreviewSummary({ session }: PreviewSummaryProps) {
  const experiments = session.items.filter(item => item.type === 'experiment');
  const resources = session.items.filter(item => item.type === 'resource');
  
  const documentClassifications = session.items.filter(item => 
    (item.userClassification || item.proposedClassification) === 'document'
  );
  const inventoryClassifications = session.items.filter(item => 
    (item.userClassification || item.proposedClassification) === 'inventory'
  );

  const userModified = session.items.filter(item => item.userClassification !== null);
  const totalIssues = session.items.reduce((sum, item) => sum + item.validationIssues.length, 0);
  const highConfidence = session.items.filter(item => item.confidence === 'high').length;
  const mediumConfidence = session.items.filter(item => item.confidence === 'medium').length;
  const lowConfidence = session.items.filter(item => item.confidence === 'low').length;

  const totalFiles = Object.keys(session.fileMetadata).length;
  const totalCrossRefs = session.items.reduce((sum, item) => sum + item.crossReferences.length, 0);

  return (
    <div className="bg-white rounded-lg shadow-md border border-gray-200 p-6">
      <div className="flex items-center justify-between mb-6">
        <div>
          <h2 className="text-xl font-semibold text-gray-900">Import Preview Summary</h2>
          <div className="flex items-center space-x-4 mt-2 text-sm text-gray-600">
            <span className="flex items-center space-x-1">
              <Calendar className="h-4 w-4" />
              <span>{new Date(session.createdAt).toLocaleString()}</span>
            </span>
            <span className="flex items-center space-x-1">
              <Hash className="h-4 w-4" />
              <span>{session.id.substring(0, 8)}</span>
            </span>
          </div>
        </div>
        <div className="text-right">
          <div className="text-2xl font-bold text-gray-900">{session.totalItems}</div>
          <div className="text-sm text-gray-600">Total Items</div>
        </div>
      </div>

      {/* File Info */}
      <div className="mb-6 p-4 bg-blue-50 rounded-lg">
        <div className="flex items-center space-x-2 mb-2">
          <FileText className="h-5 w-5 text-blue-600" />
          <span className="font-medium text-blue-900">Source File</span>
        </div>
        <div className="text-sm text-blue-800">
          <div className="font-medium">{session.elnFileName}</div>
          <div className="mt-1">
            {totalFiles} attached files • {totalCrossRefs} cross-references
          </div>
        </div>
      </div>

      {/* Content Breakdown */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <div>
          <h3 className="text-lg font-medium text-gray-900 mb-3">Content Breakdown</h3>
          <div className="space-y-3">
            <div className="flex items-center justify-between">
              <div className="flex items-center space-x-2">
                <FileText className="h-4 w-4 text-blue-600" />
                <span className="text-sm text-gray-700">Experiments</span>
              </div>
              <span className="text-sm font-medium text-gray-900">{experiments.length}</span>
            </div>
            <div className="flex items-center justify-between">
              <div className="flex items-center space-x-2">
                <Package className="h-4 w-4 text-purple-600" />
                <span className="text-sm text-gray-700">Resources</span>
              </div>
              <span className="text-sm font-medium text-gray-900">{resources.length}</span>
            </div>
          </div>
        </div>

        <div>
          <h3 className="text-lg font-medium text-gray-900 mb-3">Proposed Classifications</h3>
          <div className="space-y-3">
            <div className="flex items-center justify-between">
              <div className="flex items-center space-x-2">
                <FileText className="h-4 w-4 text-blue-600" />
                <span className="text-sm text-gray-700">→ Documents</span>
              </div>
              <span className="text-sm font-medium text-gray-900">{documentClassifications.length}</span>
            </div>
            <div className="flex items-center justify-between">
              <div className="flex items-center space-x-2">
                <Package className="h-4 w-4 text-purple-600" />
                <span className="text-sm text-gray-700">→ Inventory Items</span>
              </div>
              <span className="text-sm font-medium text-gray-900">{inventoryClassifications.length}</span>
            </div>
          </div>
        </div>
      </div>

      {/* Confidence & Issues */}
      <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <div>
          <h3 className="text-lg font-medium text-gray-900 mb-3">Classification Confidence</h3>
          <div className="space-y-2">
            <div className="flex items-center justify-between">
              <span className="text-sm text-green-700">High</span>
              <span className="text-sm font-medium">{highConfidence}</span>
            </div>
            <div className="flex items-center justify-between">
              <span className="text-sm text-yellow-700">Medium</span>
              <span className="text-sm font-medium">{mediumConfidence}</span>
            </div>
            <div className="flex items-center justify-between">
              <span className="text-sm text-red-700">Low</span>
              <span className="text-sm font-medium">{lowConfidence}</span>
            </div>
          </div>
        </div>

        <div>
          <h3 className="text-lg font-medium text-gray-900 mb-3">User Modifications</h3>
          <div className="flex items-center space-x-2">
            <Users className="h-5 w-5 text-blue-600" />
            <span className="text-lg font-semibold text-gray-900">{userModified.length}</span>
            <span className="text-sm text-gray-600">items modified</span>
          </div>
        </div>

        <div>
          <h3 className="text-lg font-medium text-gray-900 mb-3">Validation Issues</h3>
          <div className="flex items-center space-x-2">
            {totalIssues > 0 ? (
              <>
                <AlertTriangle className="h-5 w-5 text-yellow-600" />
                <span className="text-lg font-semibold text-yellow-700">{totalIssues}</span>
                <span className="text-sm text-gray-600">issues found</span>
              </>
            ) : (
              <>
                <CheckCircle className="h-5 w-5 text-green-600" />
                <span className="text-sm text-green-700">No issues</span>
              </>
            )}
          </div>
        </div>
      </div>

      {/* Categories */}
      <div>
        <h3 className="text-lg font-medium text-gray-900 mb-3">Categories</h3>
        <div className="flex flex-wrap gap-2">
          {Array.from(new Set(session.items.map(item => item.category))).map(category => {
            const categoryItems = session.items.filter(item => item.category === category);
            const categoryColor = categoryItems[0]?.categoryColor || '#666666';
            
            return (
              <span
                key={category}
                className="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium"
                style={{
                  backgroundColor: `${categoryColor}20`,
                  color: categoryColor
                }}
              >
                {category} ({categoryItems.length})
              </span>
            );
          })}
        </div>
      </div>

      {/* Quick Actions */}
      <div className="mt-6 pt-6 border-t border-gray-200">
        <div className="flex items-center justify-between">
          <div className="text-sm text-gray-600">
            Ready to import {session.totalItems} items to RSpace
          </div>
          <div className="flex items-center space-x-2 text-sm">
            {totalIssues > 0 && (
              <span className="flex items-center space-x-1 text-yellow-600">
                <AlertTriangle className="h-4 w-4" />
                <span>Review issues before import</span>
              </span>
            )}
            {userModified.length > 0 && (
              <span className="flex items-center space-x-1 text-blue-600">
                <Users className="h-4 w-4" />
                <span>{userModified.length} user modifications</span>
              </span>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}