import { PreviewItem } from '../types/eln';

export type FilterType = 'all' | 'experiments' | 'resources' | 'high' | 'medium' | 'low' | 'modified' | 'issues';
export type SortType = 'name' | 'type' | 'confidence' | 'created' | 'modified';

export function filterItems(items: PreviewItem[], filter: FilterType, searchQuery: string): PreviewItem[] {
  return items.filter(item => {
    if (searchQuery) {
      const query = searchQuery.toLowerCase();
      const matchesSearch =
        item.name.toLowerCase().includes(query) ||
        item.category.toLowerCase().includes(query) ||
        item.textContent.toLowerCase().includes(query) ||
        item.keywords.some(k => k.toLowerCase().includes(query));

      if (!matchesSearch) return false;
    }

    switch (filter) {
      case 'experiments':
        return item.type === 'experiment';
      case 'resources':
        return item.type === 'resource';
      case 'high':
        return item.confidence === 'high';
      case 'medium':
        return item.confidence === 'medium';
      case 'low':
        return item.confidence === 'low';
      case 'modified':
        return item.userClassification !== null;
      case 'issues':
        return item.validationIssues.length > 0;
      default:
        return true;
    }
  });
}

export function sortItems(items: PreviewItem[], sortBy: SortType): PreviewItem[] {
  return [...items].sort((a, b) => {
    switch (sortBy) {
      case 'name':
        return a.name.localeCompare(b.name);
      case 'type':
        return a.type.localeCompare(b.type);
      case 'confidence':
        const confidenceOrder = { high: 3, medium: 2, low: 1 };
        return confidenceOrder[b.confidence as keyof typeof confidenceOrder] -
               confidenceOrder[a.confidence as keyof typeof confidenceOrder];
      case 'created':
        return new Date(b.dateCreated).getTime() - new Date(a.dateCreated).getTime();
      case 'modified':
        return new Date(b.dateModified).getTime() - new Date(a.dateModified).getTime();
      default:
        return 0;
    }
  });
}

export function getFilterCounts(items: PreviewItem[]) {
  return {
    all: items.length,
    experiments: items.filter(i => i.type === 'experiment').length,
    resources: items.filter(i => i.type === 'resource').length,
    high: items.filter(i => i.confidence === 'high').length,
    medium: items.filter(i => i.confidence === 'medium').length,
    low: items.filter(i => i.confidence === 'low').length,
    modified: items.filter(i => i.userClassification !== null).length,
    issues: items.filter(i => i.validationIssues.length > 0).length
  };
}
