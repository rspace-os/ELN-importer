{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "electron",
    "outDir": "dist-electron",
    "module": "CommonJS",
    "target": "ES2020",
    "lib": ["ES2020"],
    "moduleResolution": "Node",
    "types": ["node"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["electron/**/*.ts"]
}
